# ── Firebase ──────────────────────────────────────
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
# OR paste JSON directly (for Railway deployment)
FIREBASE_CREDENTIALS_JSON=

# ── Razorpay ──────────────────────────────────────
# From Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend (email) ────────────────────────────────
# From resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@tejasai.io

# ── App ───────────────────────────────────────────
APP_SECRET_KEY=change-this-to-a-random-secret-string-64-chars
ALLOWED_ORIGINS=http://localhost:3000,https://tejasai.io
ENVIRONMENT=development
